POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_FUNDER=

# Default is paper trading. Real orders are blocked unless this is true
# and all trading credentials are present.
REAL_TRADING=false

MAX_POSITION_PCT=0.10
MAX_DAILY_LOSS_PCT=0.20
EDGE_HIGH=0.16
# Retained for experiments/backtests. Live risk gate requires EDGE_HIGH.
EDGE_MEDIUM=0.08
MIN_CONFIDENCE_HIGH=85
# Retained for experiments/backtests. Live risk gate requires MIN_CONFIDENCE_HIGH.
MIN_CONFIDENCE_MEDIUM=75
PAPER_STARTING_BALANCE=1000

MARKET_URL=https://polymarket.com/id/event/btc-updown-5m-1778690700
DATABASE_URL=sqlite:///bot.sqlite3

# Optional Chainlink source. If unset, the bot requires Binance and Coinbase
# to agree closely before it will trade.
CHAINLINK_RPC_URL=
CHAINLINK_BTC_USD_FEED_ADDRESS=

# Safety defaults.
MAX_SPREAD=0.04
MAX_SLIPPAGE=0.02
MIN_LIQUIDITY_MULTIPLE=3
MAX_TRADES_PER_HOUR=12
MAX_CONSECUTIVE_LOSSES=3
CONSECUTIVE_LOSS_PAUSE_MINUTES=30
ENTRY_MIN_SECONDS_TO_CLOSE=20
ENTRY_MAX_SECONDS_TO_CLOSE=150
ENTRY_IDEAL_MIN_SECONDS_TO_CLOSE=45
MAX_FEED_DEVIATION_BPS=20
POLL_SECONDS=2
